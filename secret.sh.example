# FormulaGo Secret Environment Variables
# DO NOT commit this file to git — it contains sensitive credentials.
#
# Usage:
#   Linux/macOS (bash/zsh): source secret.sh
#   Windows (Git Bash):     source secret.sh
#   Windows (PowerShell):   Get-Content secret.sh | Foreach-Object { if ($_ -match '^export (.+?)="(.+)"$') { Set-Item -Path "env:$($matches[1])" -Value $matches[2] } }
#   Windows (CMD):          for /f "tokens=1,2 delims== " %a in ('type secret.sh ^| findstr /b "export"') do set %a=%b
#
# Edit the values below to match your environment before sourcing.
#
# Verify:
#   echo $DB_PASSWORD         # Linux/macOS/Git Bash
#   echo %DB_PASSWORD%        # Windows CMD
#   $env:DB_PASSWORD          # Windows PowerShell

export DB_PASSWORD="change-me"
export ACCESS_SECRET="change-me"
export OAUTH_KEY="change-me"
export REDIS_PASSWORD="change-me"
export OSS_SECRET_ID="change-me"
export OSS_SECRET_KEY="change-me"
export WECOM_CORP_ID="change-me"
export WECOM_SECRET_ID="change-me"
export WECOM_TOKEN="change-me"
export WECOM_AES_KEY="change-me"
